[include]
  path = ~/.config/git/common.gitconfig
[includeIf "gitdir:~/.dotfiles"]
  path = ~/.config/git/users/personal.gitconfig
[includeIf "gitdir:/root/code/kosmonaut/"]
  path = ~/.config/git/users/kosmonaut.gitconfig
[includeIf "gitdir:/root/code/monka/"]
  path = ~/.config/git/users/monka.gitconfig
[includeIf "gitdir:/root/code/personal/"]
  path = ~/.config/git/users/personal.gitconfig
[includeIf "gitdir:/root/code/work/"]
  path = ~/.config/git/users/work.gitconfig
