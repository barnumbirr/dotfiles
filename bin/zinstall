#!/bin/sh
#
# zinstall - Painless Zig installation
#
# TODO
# allow downloading "master" Ziglang (use https://zigbin.io/master/x86_64-linux.tar.xz ?)
#

set -eu

PROG_NAME="${0##*/}"
VERSION=0.13.0
ARCH=x86_64

msg() { printf '%s: %b\n' "$PROG_NAME" "$*" >&2; }

die() {
  _die_rc=1
  case "${1-}" in [0-9]*) _die_rc="$1"; shift ;; esac
  msg "error: $*"
  exit "$_die_rc"
}

usage() {
  cat <<EOF
Usage: $PROG_NAME [options]

Download and install Zig.

Options:
  -a, --arch ARCHITECTURE    specify host architecture (default: x86_64)
  -v, --version VERSION      specify Zig version to install (default: 0.13.0)

  -V, --verbose              output debug information
  -h, --help                 display this help message and exit
EOF
}

require_root() {
  [ "$(id -u)" -eq 0 ] || die "permission denied, please run as root"
}

download() {
  wget "https://ziglang.org/download/${VERSION}/zig-linux-${ARCH}-${VERSION}.tar.xz"
}

install() {
  tar xvf "zig-linux-${ARCH}-${VERSION}.tar.xz"
  if [ -d /usr/local/zig ]; then
    rm -rf /usr/local/zig
  fi
  mv --verbose "zig-linux-${ARCH}-${VERSION}" /usr/local/zig
  rm --verbose "zig-linux-${ARCH}-${VERSION}.tar.xz"
}

conftest() {
  if ! grep -qxF 'export PATH=$PATH:/usr/local/zig' "$HOME/.profile"; then
    echo 'export PATH=$PATH:/usr/local/zig' >> "$HOME/.profile"
  fi
  export PATH=$PATH:/usr/local/zig

  zig help
  zig version
}

main() {
  require_root
  download
  install
  conftest
}

parse_params() {
  while [ "$#" -gt 0 ]; do
    case "$1" in
      -h | --help)    usage; exit 0 ;;
      -V | --verbose) set -x ;;
      -a | --arch)
        [ "${2-}" ] || die "missing value after $1"
        ARCH="$2"
        shift
        ;;
      -v | --version)
        [ "${2-}" ] || die "missing value after $1"
        VERSION="$2"
        shift
        ;;
      -?*) die "unknown option: $1\nTry '$PROG_NAME -h' for more information." ;;
      *)   break ;;
    esac
    shift
  done

  main
}

parse_params "$@"
