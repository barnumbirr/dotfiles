#!/bin/sh
#
# pkg - APT magic
#

set -eu

PROG_NAME="${0##*/}"
BACKUP_DIRECTORY="/var/backups/apt"

msg() { printf '%s: %b\n' "$PROG_NAME" "$*" >&2; }

die() {
  _die_rc=1
  case "${1-}" in [0-9]*) _die_rc="$1"; shift ;; esac
  msg "error: $*"
  exit "$_die_rc"
}

usage() {
  cat <<EOF
Usage: $PROG_NAME <command> [args]

Commands:
  backup [DIR]    save installed/marked packages, GPG keys and sources
  files PKG       list files installed to system from package
  list PATTERN    list all known packages matching one or more patterns
  lock PKG        lock package to currently installed version
  restore [DIR]   restore backup from directory
  search PATTERN  search for packages that own files corresponding to the given patterns
  unlock PKG      unlock previously locked package

Options:
  -h, --help      display this help message and exit
EOF
}

require_root() {
  [ "$(id -u)" -eq 0 ] || die "permission denied, please run as root"
}

cmd_backup() {
  _bk_dir="${1:-$BACKUP_DIRECTORY}"

  if [ ! -d "$_bk_dir" ]; then
    mkdir -pv "$_bk_dir"
  else
    msg "directory $_bk_dir already exists, skipping creation..."
  fi

  cp -R /etc/apt/sources.list* "$_bk_dir/"
  cp -R /usr/share/keyrings /etc/apt/keyrings "$_bk_dir"
  dpkg --get-selections > "$_bk_dir/packages.txt"
  apt-mark showauto > "$_bk_dir/marked.txt" 2>/dev/null

  echo "Backup completed. Files saved to $_bk_dir"
}

cmd_files() {
  dpkg-query --listfiles "$1"
}

cmd_list() {
  dpkg-query --list "$1"
}

cmd_lock() {
  apt-mark hold "$1"
}

cmd_restore() {
  _rs_dir="${1:-$BACKUP_DIRECTORY}"

  cp -R "$_rs_dir/keyrings" /usr/share/
  cp -R "$_rs_dir/sources.list"* /etc/apt/
  [ -d "$_rs_dir/keyrings" ] && cp -R "$_rs_dir/keyrings" /etc/apt/ 2>/dev/null || true
  _rs_tmp=$(mktemp)
  apt-cache dumpavail > "$_rs_tmp" && dpkg --merge-avail "$_rs_tmp"
  rm -f "$_rs_tmp"
  dpkg --clear-selections
  dpkg --set-selections < "$_rs_dir/packages.txt"
  xargs apt-mark auto < "$_rs_dir/marked.txt"

  echo "Restore completed."
}

cmd_search() {
  dpkg-query --search "$1"
}

cmd_unlock() {
  apt-mark unhold "$1"
}

parse_params() {
  while [ "$#" -gt 0 ]; do
    case "$1" in
      -h | --help)    usage; exit 0 ;;
      -V | --verbose) set -x ;;
      backup)  require_root; shift; cmd_backup "${1-}"; return ;;
      files)   shift; cmd_files "${1-}"; return ;;
      list)    shift; cmd_list "${1-}"; return ;;
      lock)    require_root; shift; cmd_lock "${1-}"; return ;;
      restore) require_root; shift; cmd_restore "${1-}"; return ;;
      search)  shift; cmd_search "${1-}"; return ;;
      unlock)  require_root; shift; cmd_unlock "${1-}"; return ;;
      -?*) die "unknown option: $1\nTry '$PROG_NAME -h' for more information." ;;
      *)   die "unknown command: $1\nTry '$PROG_NAME -h' for more information." ;;
    esac
    shift
  done

  die "missing command.\nTry '$PROG_NAME -h' for more information."
}

parse_params "$@"
