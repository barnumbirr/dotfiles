#!/bin/sh
#
# git-ssh-origin - HTTPS to SSH Git origin URLs
#

set -eu

PROG_NAME="${0##*/}"

msg() { printf '%s: %b\n' "$PROG_NAME" "$*" >&2; }

die() {
  _die_rc=1
  case "${1-}" in [0-9]*) _die_rc="$1"; shift ;; esac
  msg "error: $*"
  exit "$_die_rc"
}

usage() {
  cat <<EOF
Usage: $PROG_NAME [options]

Convert the Git origin remote from HTTPS to SSH URL.

Options:
  -V, --verbose    output debug information
  -h, --help       display this help message and exit
EOF
}

main() {
  _main_orig=$(git remote get-url origin 2>/dev/null) || die "not in a git repository or no 'origin' remote"

  if [ "${_main_orig#git@}" != "$_main_orig" ]; then
    echo "Already an SSH URL: $_main_orig"
    return
  fi

  _main_updated=$(echo "$_main_orig" | sed 's|https://|git@|; s|/|:|')

  if git remote set-url origin "$_main_updated"; then
    echo "Origin URL was updated"
    echo "Original URL: $_main_orig"
    echo "Updated URL: $_main_updated"
  else
    die "failed to update Git origin URL"
  fi
}

parse_params() {
  while [ "$#" -gt 0 ]; do
    case "$1" in
      -h | --help)    usage; exit 0 ;;
      -V | --verbose) set -x ;;
      -?*) die "unknown option: $1\nTry '$PROG_NAME -h' for more information." ;;
      *)   break ;;
    esac
    shift
  done

  main "$@"
}

parse_params "$@"
