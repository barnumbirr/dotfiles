#!/bin/sh
#
# nfo - dead simple NFO viewer
#

set -eu

PROG_NAME="${0##*/}"

msg() { printf '%s: %b\n' "$PROG_NAME" "$*" >&2; }

die() {
  _die_rc=1
  case "${1-}" in [0-9]*) _die_rc="$1"; shift ;; esac
  msg "error: $*"
  exit "$_die_rc"
}

usage() {
  cat <<EOF
Usage: $PROG_NAME [options] FILE

Display NFO files (cp437 encoded) in the terminal.

Options:
  -V, --verbose    output debug information
  -h, --help       display this help message and exit
EOF
}

main() {
  [ -f "$1" ] || die "the argument is not a file or does not exist"

  case "${1##*.}" in
    [Nn][Ff][Oo]) ;;
    *)   die "the file does not look like an NFO" ;;
  esac

  iconv -f cp437 "$1"
}

parse_params() {
  while [ "$#" -gt 0 ]; do
    case "$1" in
      -h | --help)    usage; exit 0 ;;
      -V | --verbose) set -x ;;
      -?*) die "unknown option: $1\nTry '$PROG_NAME -h' for more information." ;;
      *)   break ;;
    esac
    shift
  done

  [ "${1-}" ] || die "FILE is required.\nTry '$PROG_NAME -h' for more information."

  main "$@"
}

parse_params "$@"
