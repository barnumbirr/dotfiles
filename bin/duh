#!/bin/sh
#
# duh - du for humans
#

set -eu

PROG_NAME="${0##*/}"

msg() { printf '%s: %b\n' "$PROG_NAME" "$*" >&2; }

die() {
  _die_rc=1
  case "${1-}" in [0-9]*) _die_rc="$1"; shift ;; esac
  msg "error: $*"
  exit "$_die_rc"
}

usage() {
  cat <<EOF
Usage: $PROG_NAME [options]

Show largest files/directories by size.

Options:
  -d, --directory DIRECTORY    set working directory (default: \$PWD)
  -n, --number NUMBER          return number of lines (default: 20)

  -V, --verbose                output debug information
  -h, --help                   display this help message and exit
EOF
}

main() {
  [ -d "${DIRECTORY:-.}" ] || die "directory not found: ${DIRECTORY:-.}"
  du -ah 2>/dev/null "${DIRECTORY:-.}" |
  sort -rh |
  head -n "${NUMBER:-20}"
}

parse_params() {
  DIRECTORY=""
  NUMBER=""

  while [ "$#" -gt 0 ]; do
    case "$1" in
      -h | --help)    usage; exit 0 ;;
      -V | --verbose) set -x ;;
      -d | --directory)
        [ "${2-}" ] || die "missing value after $1"
        DIRECTORY="$2"
        shift
        ;;
      -n | --number)
        [ "${2-}" ] || die "missing value after $1"
        NUMBER="$2"
        shift
        ;;
      -?*) die "unknown option: $1\nTry '$PROG_NAME -h' for more information." ;;
      *)   break ;;
    esac
    shift
  done

  main "$@"
}

parse_params "$@"
