#!/bin/sh
#
# gh-release - Get latest release version from Github repository
#

set -eu

PROG_NAME="${0##*/}"

msg() { printf '%s: %b\n' "$PROG_NAME" "$*" >&2; }

die() {
  _die_rc=1
  case "${1-}" in [0-9]*) _die_rc="$1"; shift ;; esac
  msg "error: $*"
  exit "$_die_rc"
}

usage() {
  cat <<EOF
Usage: $PROG_NAME [options] USERNAME/REPO

Fetch the latest release version from a GitHub repository.

Options:
  -V, --verbose    output debug information
  -h, --help       display this help message and exit
EOF
}

main() {
  _main_resp=$(curl --silent --fail "https://api.github.com/repos/${1}/releases/latest") || \
    die "failed to fetch release info for $1"

  _main_version=$(echo "$_main_resp" | sed -n 's/.*"tag_name": *"\([^"]*\)".*/\1/p')

  if [ -z "$_main_version" ]; then
    die "could not parse release version for $1"
  fi

  echo "$_main_version (https://github.com/${1})"
}

parse_params() {
  while [ "$#" -gt 0 ]; do
    case "$1" in
      -h | --help)    usage; exit 0 ;;
      -V | --verbose) set -x ;;
      -?*) die "unknown option: $1\nTry '$PROG_NAME -h' for more information." ;;
      *)   break ;;
    esac
    shift
  done

  [ "${1-}" ] || die "USERNAME/REPO is required.\nTry '$PROG_NAME -h' for more information."

  main "$@"
}

parse_params "$@"
