#!/bin/sh
#
# git-branches - Per branch git history
#

set -eu

PROG_NAME="${0##*/}"

msg() { printf '%s: %b\n' "$PROG_NAME" "$*" >&2; }

die() {
  _die_rc=1
  case "${1-}" in [0-9]*) _die_rc="$1"; shift ;; esac
  msg "error: $*"
  exit "$_die_rc"
}

usage() {
  cat <<EOF
Usage: $PROG_NAME [options]

Show last commit date, author, and name for each remote branch.

Options:
  -V, --verbose   output debug information
  -h, --help      display this help message and exit
EOF
}

pad_string() {
  printf "%-${2}s" "$1"
}

main() {
  GIT_DIR=$(git rev-parse --git-dir 2>/dev/null) ||
    { [ -d ".dotfiles" ] && GIT_DIR=".dotfiles"; } ||
    die "not a git repository"

  export GIT_DIR

  _main_data=$(git branch -r | grep -v HEAD | while read -r _main_branch; do
    _main_commit_data=$(git log -1 --format="%ci%x01%cr%x01%an" "$_main_branch")
    _main_date=$(printf '%s' "$_main_commit_data" | cut -d"$(printf '\001')" -f1)
    _main_rel=$(printf '%s' "$_main_commit_data" | cut -d"$(printf '\001')" -f2)
    _main_author=$(printf '%s' "$_main_commit_data" | cut -d"$(printf '\001')" -f3)
    _main_info=$(pad_string "$_main_date ($_main_rel)" 56)
    _main_ainfo=$(pad_string "$_main_author" 25)
    printf "%s%s%s\n" "$_main_info" "$_main_ainfo" "${_main_branch#*/}"
  done | sort -r)

  printf "%-56s%-25s%-s\n" "Commit Date" "Commit Author" "Branch"
  printf "%-56s%-25s%-s\n" "-----------" "-------------" "------"
  printf "%s\n" "$_main_data"
}

parse_params() {
  while [ "$#" -gt 0 ]; do
    case "$1" in
      -h | --help)    usage; exit 0 ;;
      -V | --verbose) set -x ;;
      -?*) die "unknown option: $1\nTry '$PROG_NAME -h' for more information." ;;
      *)   break ;;
    esac
    shift
  done

  main "$@"
}

parse_params "$@"
