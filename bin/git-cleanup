#!/bin/sh
#
# git-cleanup - Clean up local git branches whose upstream is gone
#

set -eu

PROG_NAME="${0##*/}"
VERSION="1.0.0"

msg() { printf '%s: %b\n' "$PROG_NAME" "$*" >&2; }

die() {
  _die_rc=1
  case "${1-}" in [0-9]*) _die_rc="$1"; shift ;; esac
  msg "error: $*"
  exit "$_die_rc"
}

info() { printf '%s\n' "$*" >&2; }

usage() {
  cat <<EOF
Usage: $PROG_NAME [options]

Clean up local git branches whose upstream is gone.

Options:
  -f, --force      force delete branches (use -D instead of -d)
  -q, --quiet      suppress informational messages
  --version        display version information and exit

  -V, --verbose    output debug information
  -h, --help       display this help message and exit
EOF
}

cleanup_branches() {
  info "Fetching and pruning remotes..."
  git fetch --all --prune

  info "Looking for branches with gone upstreams..."
  _cb_branches=$(git branch -vv | awk '/\[gone\]/{print ($1=="*") ? $2 : $1}')

  if [ -z "$_cb_branches" ]; then
    info "No local branches with gone upstreams found."
    return
  fi

  info "Branches to delete:"
  printf '%s\n' "$_cb_branches"

  if [ "$OPT_FORCE" = true ]; then
    info "Force deleting..."
    printf '%s\n' "$_cb_branches" | xargs -r git branch -D
  else
    info "Safely deleting (only if merged)..."
    printf '%s\n' "$_cb_branches" | xargs -r git branch -d
  fi
}

clean_exit() {
  _ce_status=$?
  trap - EXIT
  [ $# -ne 0 ] && {
    trap - "$1"
    kill -s "$1" $$
  }
  exit "$_ce_status"
}

parse_params() {
  OPT_FORCE=false
  OPT_QUIET=false

  trap 'clean_exit' EXIT TERM
  trap 'clean_exit HUP' HUP
  trap 'clean_exit INT' INT

  while [ "$#" -gt 0 ]; do
    case "$1" in
      -h | --help)    usage; exit 0 ;;
      -V | --verbose) set -x ;;
      --version)      printf '%s v%s\n' "$PROG_NAME" "$VERSION"; exit 0 ;;
      -q | --quiet)   OPT_QUIET=true; info() { :; } ;;
      -f | --force)   OPT_FORCE=true ;;
      -?*) die "unknown option: $1\nTry '$PROG_NAME -h' for more information." ;;
      *)   break ;;
    esac
    shift
  done

  cleanup_branches
}

parse_params "$@"
