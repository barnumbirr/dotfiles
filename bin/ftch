#!/bin/sh
#
# ftch - a simpler neofetch
#

set -eu

printf '%s\n' """
    ___      ${USER:-$(id -un)}@$(cat /etc/hostname)
   (.. |     os:     $(. /etc/os-release; echo "${PRETTY_NAME}")
   (<> |     kernel: $(uname -r)
  / __  \    uptime: $(awk '{d=int($1/86400);h=int($1%86400/3600);m=int($1%3600/60);printf "%dd %dh %dm",d,h,m}' /proc/uptime)
 ( /  \ /|   pkgs:   $(dpkg --get-selections 2>/dev/null | grep -c '[[:space:]]install$' || echo "0")
_/\ __)/_)   cpu:    $(awk -F'(: )+' '/^model name/{ print $2;exit }' /proc/cpuinfo)\
 ($(awk '/^processor/ { N++} END { print N }' /proc/cpuinfo))
\/-____\/    memory: $(free -m | awk 'NR==2{printf "%.0f / %.0fMiB\n", $3, $2}')
             shell:  ${SHELL##*/}
"""
