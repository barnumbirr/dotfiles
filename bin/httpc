main() {
  _main_code="$1"
  _main_wiki="https://en.wikipedia.org/wiki/List_of_HTTP_status_codes"

  _main_out=$(printf '%s\n' "$HTTP_DATA" | awk -F'|' -v code="$_main_code" -v wiki="$_main_wiki" \
    '$1 == code {
      anchor = ($4 != "") ? $4 : $1
      printf "%s %s - %s#%s\n", $1, $2, wiki, anchor
      found = 1
    }
    END { if (!found) exit 1 }') || \
    die "unknown HTTP status code: $_main_code"

  printf '%s\n' "$_main_out"
}

parse_params() {
  while [ "$#" -gt 0 ]; do
    case "$1" in
      -h | --help)    usage; exit 0 ;;
      -V | --verbose) set -x ;;
      -?*) die "unknown option: $1\nTry '$PROG_NAME -h' for more information." ;;
      *)   break ;;
    esac
    shift
  done

  [ "${1-}" ] || die "HTTP_STATUS_CODE is required.\nTry '$PROG_NAME -h' for more information."

  for _pp_code do
    main "$_pp_code"
  done
}

parse_params "$@"
