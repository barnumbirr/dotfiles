#!/bin/sh
#
# httpc - HTTP status code information
#

set -eu

PROG_NAME="${0##*/}"

msg() { printf '%s: %b\n' "$PROG_NAME" "$*" >&2; }

die() {
  _die_rc=1
  case "${1-}" in [0-9]*) _die_rc="$1"; shift ;; esac
  msg "error: $*"
  exit "$_die_rc"
}

usage() {
  cat <<EOF
Usage: $PROG_NAME [options] HTTP_STATUS_CODE

Look up an HTTP status code and print its description.

Options:
  -V, --verbose    output debug information
  -h, --help       display this help message and exit
EOF
}

HTTP_DATA='100|Continue
101|Switching Protocols
102|Processing (WebDAV; RFC 2518)
103|Early Hints (RFC 8297)
110|Response is Stale (obsoleted caching warning)|unofficial|1xx_informational_response
