#!/bin/sh
#
# vault - Pastebin-like service
# https://github.com/barnumbirr/vault
#

set -eu

PROG_NAME="${0##*/}"

msg() { printf '%s: %b\n' "$PROG_NAME" "$*" >&2; }

die() {
  _die_rc=1
  case "${1-}" in [0-9]*) _die_rc="$1"; shift ;; esac
  msg "error: $*"
  exit "$_die_rc"
}

usage() {
  cat <<EOF
Usage: $PROG_NAME [options] [FILE]

Upload a file to vault.tf. Reads from stdin if no FILE is given.

Options:
  -V, --verbose    output debug information
  -h, --help       display this help message and exit
EOF
}

_extract_key() {
  if command -v jq >/dev/null 2>&1; then
    echo "$1" | jq -r .key
  else
    echo "$1" | sed 's/.*"key":"\([^"]*\)".*/\1/'
  fi
}

main() {
  [ "${VAULT_SECRET_KEY-}" ] || die "VAULT_SECRET_KEY is not set"

  _main_url="https://vault.tf"

  _main_resp=$(curl --silent --fail --data-binary @"${1:--}" \
    -H "Authorization: $VAULT_SECRET_KEY" "$_main_url/documents") || \
    die "failed to paste"

  _main_key=$(_extract_key "$_main_resp")
  [ -n "$_main_key" ] || die "failed to parse response"

  echo "$_main_url/$_main_key"
}

parse_params() {
  while [ "$#" -gt 0 ]; do
    case "$1" in
      -h | --help)    usage; exit 0 ;;
      -V | --verbose) set -x ;;
      -?*) die "unknown option: $1\nTry '$PROG_NAME -h' for more information." ;;
      *)   break ;;
    esac
    shift
  done

  main "${1:--}"
}

parse_params "$@"
